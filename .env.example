DEBUG=False
SECRET_KEY=change-this-secret-key
ALLOWED_HOSTS=your-backend-domain.onrender.com,.vercel.app,.onrender.com,.railway.app

# Supabase PostgreSQL connection string. Use the pooled connection URL if available.
# Example:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=
DB_SSL_REQUIRE=True

# Frontend origins allowed to call the API.
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app
CORS_ALLOWED_ORIGIN_REGEXES=https://.*\.vercel\.app,https://.*\.onrender\.com,https://.*\.railway\.app
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.vercel.app

# Use these when frontend and backend are on different HTTPS domains.
SESSION_COOKIE_SAMESITE=None
CSRF_COOKIE_SAMESITE=None
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Optional: initial professor account, used by python manage.py bootstrap_admin.
ADMIN_USERNAME=profesor
ADMIN_PASSWORD=change-this-admin-password
ADMIN_EMAIL=profesor@example.com
ADMIN_FIRST_NAME=Profesor
ADMIN_LAST_NAME=Principal
